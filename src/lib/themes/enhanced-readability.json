{
  "meta": {
    "name": "Enhanced Readability",
    "type": "modifier",
    "trigger": "manual",
    "description": "Larger text, wider spacing for extended reading",
    "schemaVersion": 1
  },
  "typography": {
    "--font-size-sm": "0.875rem",
    "--font-size-base": "1.125rem",
    "--font-size-md": "1.375rem",
    "--font-size-lg": "1.75rem",
    "--font-size-hero": "2.5rem",
    "--line-height-base": 1.8,
    "--letter-spacing": "0.05em",
    "--word-spacing": "0.1em"
  },
  "spacing": {
    "--space-1": "0.375rem",
    "--space-2": "0.625rem",
    "--space-3": "1rem",
    "--space-4": "1.25rem",
    "--space-5": "1.75rem",
    "--space-6": "2.5rem"
  },
  "borders": {
    "--border-width": "3px"
  },
  "transitions": {
    "--transition-fast": "0.15s ease",
    "--transition-normal": "0.3s ease"
  },
  "when-dark": {
    "typography": {
      "--font-weight-body": 500,
      "--font-weight-heading": 600
    }
  },
  "when-light": {
    "typography": {
      "--font-weight-body": 500,
      "--font-weight-heading": 600
    }
  }
}
