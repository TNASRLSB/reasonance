{
  "meta": {
    "name": "Reasonance Light",
    "author": "Reasonance Team",
    "version": "1.0.0",
    "description": "Default light brutalist theme",
    "type": "theme",
    "colorScheme": "light",
    "editorTheme": "forge-light",
    "schemaVersion": 1
  },
  "colors": {
    "--bg-primary": "#fafafa",
    "--bg-secondary": "#f0f0f0",
    "--bg-tertiary": "#e5e5e5",
    "--bg-hover": "rgba(0, 0, 0, 0.04)",
    "--bg-surface": "#ffffff",
    "--border": "#d4d4d4",
    "--text-primary": "#0a0a0a",
    "--text-body": "#1a1a1a",
    "--text-secondary": "#404040",
    "--text-muted": "#505050",
    "--accent": "#3b82f6",
    "--accent-text": "#1a44c2",
    "--accent-hover": "#2563eb",
    "--accent-statusbar": "#1e40af",
    "--danger": "#b91c1c",
    "--danger-dark": "#991b1b",
    "--danger-text": "#991b1b",
    "--success": "#16a34a",
    "--success-text": "#0e5929",
    "--warning": "#ca8a04",
    "--warning-text": "#7c4a0d",
    "--accent-btn": "#1e40af",
    "--danger-btn": "#991b1b",
    "--text-on-accent": "#ffffff",
    "--code-bg": "oklch(0.96 0.01 240)",
    "--code-accent": "oklch(0.50 0.22 320)"
  },
  "hues": {
    "--hue-accent": 220,
    "--hue-danger": 25,
    "--hue-success": 145,
    "--hue-warning": 85,
    "--hue-state-retry": 45
  },
  "states": {
    "--state-idle": "oklch(0.60 0.00 0)",
    "--state-idle-text": "oklch(0.40 0.00 0)",
    "--state-queued": "var(--warning)",
    "--state-queued-text": "var(--warning-text)",
    "--state-running": "var(--accent)",
    "--state-running-text": "var(--accent-text)",
    "--state-success": "var(--success)",
    "--state-success-text": "var(--success-text)",
    "--state-failed": "var(--danger)",
    "--state-failed-text": "var(--danger-text)",
    "--state-retrying": "oklch(0.55 0.18 var(--hue-state-retry))",
    "--state-retrying-text": "oklch(0.42 0.15 var(--hue-state-retry))"
  },
  "ui-states": {
    "--text-disabled": "oklch(0.60 0.00 0)",
    "--bg-disabled": "oklch(0.90 0.00 0)",
    "--border-disabled": "oklch(0.80 0.00 0)",
    "--bg-selected": "oklch(0.90 0.06 var(--hue-accent))",
    "--text-selected": "var(--text-primary)",
    "--text-placeholder": "oklch(0.60 0.00 0)",
    "--focus-ring-color": "oklch(0.50 0.22 var(--hue-accent))"
  },
  "typography": {
    "--font-ui": "'Atkinson Hyperlegible Next', 'Noto Sans SC', 'Noto Sans Devanagari', 'Microsoft YaHei', 'PingFang SC', system-ui, -apple-system, sans-serif",
    "--font-mono": "'Atkinson Hyperlegible Mono', monospace",
    "--font-size-sm": "0.875rem",
    "--font-size-base": "1rem",
    "--font-size-md": "1.25rem",
    "--font-size-lg": "1.5rem",
    "--font-size-hero": "2rem",
    "--font-size-small": "var(--font-size-sm)",
    "--font-size-tiny": "var(--font-size-sm)",
    "--font-size-code": "var(--font-size-base)",
    "--line-height-sm": 1.6,
    "--line-height-base": 1.5,
    "--line-height-md": 1.4,
    "--line-height-lg": 1.3,
    "--line-height-hero": 1.2,
    "--measure": "72ch",
    "--font-weight-sm": 500,
    "--font-weight-base": 400,
    "--font-weight-ui": 400,
    "--font-weight-md": 700,
    "--font-weight-lg": 700,
    "--font-weight-hero": 700,
    "--font-weight-body": 400,
    "--font-weight-heading": 700,
    "--line-height": "var(--line-height-base)",
    "--letter-spacing": "normal",
    "--word-spacing": "normal"
  },
  "spacing": {
    "--space-1": "0.25rem",
    "--space-2": "0.5rem",
    "--space-3": "0.75rem",
    "--space-4": "1rem",
    "--space-5": "1.5rem",
    "--space-6": "2rem",
    "--inset-component": "var(--space-3)",
    "--inset-section": "var(--space-4)",
    "--stack-tight": "var(--space-1)",
    "--stack-normal": "var(--space-2)",
    "--stack-loose": "var(--space-4)",
    "--interactive-gap": "var(--space-2)",
    "--paragraph-spacing": "calc(1.5 * 1.5em)",
    "--btn-padding": "var(--space-2) var(--space-3)",
    "--btn-padding-sm": "var(--space-1) var(--space-2)",
    "--panel-padding": "var(--space-4)"
  },
  "borders": {
    "--border-width": "2px",
    "--border-style": "solid",
    "--border-color": "var(--border)",
    "--radius": 0,
    "--radius-full": "50%"
  },
  "focus": {
    "--focus-ring": "2px solid var(--accent)",
    "--focus-offset": "2px"
  },
  "transitions": {
    "--transition-fast": "0.1s ease",
    "--transition-normal": "0.2s ease",
    "--toast-duration": "5s"
  },
  "layout": {
    "--toolbar-height": "44px",
    "--statusbar-height": "28px"
  },
  "layers": {
    "--layer-base": 0,
    "--layer-dropdown": 1,
    "--layer-sticky": 2,
    "--layer-overlay": 3,
    "--layer-modal": 4,
    "--layer-toast": 5
  }
}
