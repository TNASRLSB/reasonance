{
  "meta": {
    "name": "Reasonance Dark",
    "author": "Reasonance Team",
    "version": "1.0.0",
    "description": "Default dark brutalist theme",
    "type": "theme",
    "colorScheme": "dark",
    "editorTheme": "forge-dark",
    "schemaVersion": 2
  },
  "colors": {
    "--bg-primary": "#121212",
    "--bg-secondary": "#1a1a1a",
    "--bg-tertiary": "#2a2a2a",
    "--bg-hover": "rgba(255, 255, 255, 0.06)",
    "--bg-surface": "#161616",
    "--border": "#7a7a7a",
    "--text-primary": "#f0f0f0",
    "--text-body": "#d4d4d4",
    "--text-secondary": "#b5b5b5",
    "--text-muted": "#bababa",
    "--accent": "#8ab8ff",
    "--accent-text": "#93bbfc",
    "--accent-hover": "#7aabff",
    "--accent-statusbar": "#1e40af",
    "--danger": "#fa8080",
    "--danger-dark": "#991b1b",
    "--danger-text": "#fca5a5",
    "--success": "#22c55e",
    "--success-text": "#4ade80",
    "--warning": "#d4a020",
    "--warning-text": "#fbbf24",
    "--accent-btn": "#1e40af",
    "--danger-btn": "#991b1b",
    "--text-on-accent": "#ffffff",
    "--code-bg": "oklch(0.18 0.02 240)",
    "--code-accent": "oklch(0.82 0.16 320)",
    "--sidebar-bg": "#0e0e0e",
    "--sidebar-bg-hover": "rgba(255, 255, 255, 0.08)",
    "--sidebar-border": "var(--border)",
    "--sidebar-tab-active-accent": "var(--accent)",
    "--sidebar-tab-active-bg": "rgba(255, 255, 255, 0.06)",
    "--sidebar-tab-text": "var(--text-muted)",
    "--sidebar-tab-text-active": "var(--text-primary)"
  },
  "hues": {
    "--hue-accent": 220,
    "--hue-danger": 25,
    "--hue-success": 145,
    "--hue-warning": 85,
    "--hue-state-retry": 45
  },
  "states": {
    "--state-idle": "oklch(0.73 0.00 0)",
    "--state-idle-text": "oklch(0.74 0.00 0)",
    "--state-queued": "var(--warning)",
    "--state-queued-text": "var(--warning-text)",
    "--state-running": "var(--accent)",
    "--state-running-text": "var(--accent-text)",
    "--state-success": "var(--success)",
    "--state-success-text": "var(--success-text)",
    "--state-failed": "var(--danger)",
    "--state-failed-text": "var(--danger-text)",
    "--state-retrying": "oklch(0.75 0.18 var(--hue-state-retry))",
    "--state-retrying-text": "oklch(0.78 0.15 var(--hue-state-retry))",
    "--sidebar-indicator-running": "var(--success)",
    "--sidebar-indicator-idle": "oklch(0.55 0.00 0)",
    "--sidebar-indicator-unsaved": "var(--warning)",
    "--sidebar-indicator-error": "var(--danger)",
    "--sidebar-indicator-pulse": "pulse 2s ease-in-out infinite"
  },
  "ui-states": {
    "--text-disabled": "oklch(0.73 0.00 0)",
    "--bg-disabled": "oklch(0.25 0.00 0)",
    "--border-disabled": "oklch(0.54 0.00 0)",
    "--bg-selected": "oklch(0.30 0.08 var(--hue-accent))",
    "--text-selected": "var(--text-primary)",
    "--text-placeholder": "oklch(0.73 0.00 0)",
    "--focus-ring-color": "oklch(0.78 0.16 var(--hue-accent))",
    "--sidebar-dropzone-bg": "rgba(138, 184, 255, 0.08)",
    "--sidebar-dropzone-border": "var(--accent)",
    "--sidebar-separator": "rgba(255, 255, 255, 0.08)",
    "--sidebar-badge-bg": "var(--accent)",
    "--sidebar-badge-text": "var(--text-on-accent)"
  },
  "typography": {
    "--font-ui": "'Atkinson Hyperlegible Next', 'Noto Sans SC', 'Noto Sans Devanagari', 'Microsoft YaHei', 'PingFang SC', system-ui, -apple-system, sans-serif",
    "--font-mono": "'Atkinson Hyperlegible Mono', monospace",
    "--font-size-sm": "0.875rem",
    "--font-size-base": "1rem",
    "--font-size-md": "1.25rem",
    "--font-size-lg": "1.5rem",
    "--font-size-hero": "2rem",
    "--font-size-xs": "0.7rem",
    "--font-size-small": "var(--font-size-sm)",
    "--font-size-tiny": "var(--font-size-sm)",
    "--font-size-code": "var(--font-size-base)",
    "--line-height-sm": 1.6,
    "--line-height-base": 1.5,
    "--line-height-md": 1.4,
    "--line-height-lg": 1.3,
    "--line-height-hero": 1.2,
    "--measure": "72ch",
    "--font-weight-sm": 500,
    "--font-weight-base": 500,
    "--font-weight-ui": 400,
    "--font-weight-md": 700,
    "--font-weight-lg": 700,
    "--font-weight-hero": 800,
    "--font-weight-body": 500,
    "--font-weight-heading": 800,
    "--line-height": "var(--line-height-base)",
    "--letter-spacing": "normal",
    "--word-spacing": "normal"
  },
  "spacing": {
    "--space-1": "0.25rem",
    "--space-2": "0.5rem",
    "--space-3": "0.75rem",
    "--space-4": "1rem",
    "--space-5": "1.5rem",
    "--space-6": "2rem",
    "--inset-component": "var(--space-3)",
    "--inset-section": "var(--space-4)",
    "--stack-tight": "var(--space-1)",
    "--stack-normal": "var(--space-2)",
    "--stack-loose": "var(--space-4)",
    "--interactive-gap": "var(--space-2)",
    "--paragraph-spacing": "calc(1.5 * 1.5em)",
    "--btn-padding": "var(--space-2) var(--space-3)",
    "--btn-padding-sm": "var(--space-1) var(--space-2)",
    "--panel-padding": "var(--space-4)"
  },
  "borders": {
    "--border-width": "2px",
    "--border-style": "solid",
    "--border-color": "var(--border)",
    "--radius": 0,
    "--radius-full": "50%"
  },
  "focus": {
    "--focus-ring": "2px solid var(--accent)",
    "--focus-offset": "2px"
  },
  "transitions": {
    "--transition-fast": "0.1s ease",
    "--transition-normal": "0.2s ease",
    "--toast-duration": "5s",
    "--sidebar-transition-speed": "150ms"
  },
  "layout": {
    "--toolbar-height": "52px",
    "--statusbar-height": "52px",
    "--interactive-min": "44px",
    "--sidebar-width": "48px"
  },
  "layers": {
    "--layer-base": 0,
    "--layer-raised": 10,
    "--layer-sticky": 100,
    "--layer-overlay": 500,
    "--layer-dropdown": 1000,
    "--layer-modal": 2000,
    "--layer-toast": 5000,
    "--layer-top": 9999
  },
  "shadows": {
    "--shadow-sm": "0 1px 3px rgba(0, 0, 0, 0.4)",
    "--shadow-md": "0 4px 12px rgba(0, 0, 0, 0.3)",
    "--shadow-lg": "0 20px 60px rgba(0, 0, 0, 0.5)",
    "--shadow-overlay": "-4px 0 16px rgba(0, 0, 0, 0.3)"
  },
  "overlays": {
    "--overlay-bg": "rgba(0, 0, 0, 0.5)",
    "--overlay-border": "var(--border)"
  },
  "highlights": {
    "--highlight-subtle": "rgba(255, 255, 255, 0.03)",
    "--highlight-hover": "rgba(255, 255, 255, 0.06)",
    "--diff-add-bg": "rgba(22, 163, 74, 0.1)",
    "--diff-remove-bg": "rgba(220, 38, 38, 0.1)",
    "--terminal-selection": "rgba(29, 78, 216, 0.4)"
  }
}
