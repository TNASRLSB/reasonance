{
  "meta": {
    "name": "Elegant Dark",
    "author": "Reasonance Team",
    "version": "1.0.0",
    "description": "Modern, clean and refined dark theme with soft contrasts and subtle warmth",
    "type": "theme",
    "colorScheme": "dark",
    "editorTheme": "one-dark",
    "schemaVersion": 1
  },
  "colors": {
    "--bg-primary": "#1b1d23",
    "--bg-secondary": "#22252c",
    "--bg-tertiary": "#2c2f38",
    "--bg-hover": "rgba(255, 255, 255, 0.05)",
    "--bg-surface": "#1e2028",
    "--border": "rgba(255, 255, 255, 0.08)",
    "--text-primary": "#e8e9ed",
    "--text-body": "#c4c7cf",
    "--text-secondary": "#8b8fa3",
    "--text-muted": "#6c7086",
    "--accent": "#7c8af5",
    "--accent-text": "#a8b2ff",
    "--accent-hover": "#6672e0",
    "--accent-statusbar": "#3d4580",
    "--danger": "#e5534b",
    "--danger-dark": "#8b2920",
    "--danger-text": "#f5a3a0",
    "--success": "#3fb950",
    "--success-text": "#7ee787",
    "--warning": "#d29922",
    "--warning-text": "#e3b341",
    "--accent-btn": "#4c5599",
    "--danger-btn": "#8b2920",
    "--text-on-accent": "#ffffff",
    "--code-bg": "#181a20",
    "--code-accent": "#c9a0dc"
  },
  "hues": {
    "--hue-accent": 235,
    "--hue-danger": 4,
    "--hue-success": 135,
    "--hue-warning": 40,
    "--hue-state-retry": 30
  },
  "states": {
    "--state-idle": "#6c7086",
    "--state-idle-text": "#8b8fa3",
    "--state-queued": "var(--warning)",
    "--state-queued-text": "var(--warning-text)",
    "--state-running": "var(--accent)",
    "--state-running-text": "var(--accent-text)",
    "--state-success": "var(--success)",
    "--state-success-text": "var(--success-text)",
    "--state-failed": "var(--danger)",
    "--state-failed-text": "var(--danger-text)",
    "--state-retrying": "#d4943a",
    "--state-retrying-text": "#e3b66e"
  },
  "ui-states": {
    "--text-disabled": "#4c5063",
    "--bg-disabled": "#24262e",
    "--border-disabled": "rgba(255, 255, 255, 0.05)",
    "--bg-selected": "rgba(124, 138, 245, 0.12)",
    "--text-selected": "var(--text-primary)",
    "--text-placeholder": "#4c5063",
    "--focus-ring-color": "rgba(124, 138, 245, 0.5)"
  },
  "typography": {
    "--font-ui": "'Atkinson Hyperlegible Next', 'Noto Sans SC', 'Noto Sans Devanagari', 'Microsoft YaHei', 'PingFang SC', system-ui, -apple-system, sans-serif",
    "--font-mono": "'Atkinson Hyperlegible Mono', monospace",
    "--font-size-sm": "0.8125rem",
    "--font-size-base": "0.9375rem",
    "--font-size-md": "1.125rem",
    "--font-size-lg": "1.375rem",
    "--font-size-hero": "1.875rem",
    "--font-size-xs": "0.7rem",
    "--font-size-small": "var(--font-size-sm)",
    "--font-size-tiny": "var(--font-size-sm)",
    "--font-size-code": "var(--font-size-base)",
    "--line-height-sm": 1.6,
    "--line-height-base": 1.6,
    "--line-height-md": 1.5,
    "--line-height-lg": 1.4,
    "--line-height-hero": 1.25,
    "--measure": "68ch",
    "--font-weight-sm": 400,
    "--font-weight-base": 400,
    "--font-weight-ui": 400,
    "--font-weight-md": 600,
    "--font-weight-lg": 600,
    "--font-weight-hero": 700,
    "--font-weight-body": 400,
    "--font-weight-heading": 600,
    "--line-height": "var(--line-height-base)",
    "--letter-spacing": "0.01em",
    "--word-spacing": "normal"
  },
  "spacing": {
    "--space-1": "0.25rem",
    "--space-2": "0.5rem",
    "--space-3": "0.75rem",
    "--space-4": "1rem",
    "--space-5": "1.5rem",
    "--space-6": "2rem",
    "--inset-component": "var(--space-3)",
    "--inset-section": "var(--space-5)",
    "--stack-tight": "var(--space-1)",
    "--stack-normal": "var(--space-2)",
    "--stack-loose": "var(--space-4)",
    "--interactive-gap": "var(--space-2)",
    "--paragraph-spacing": "1.5em",
    "--btn-padding": "0.5rem 1rem",
    "--btn-padding-sm": "0.25rem 0.625rem",
    "--panel-padding": "var(--space-5)"
  },
  "borders": {
    "--border-width": "1px",
    "--border-style": "solid",
    "--border-color": "var(--border)",
    "--radius": "8px",
    "--radius-full": "50%"
  },
  "focus": {
    "--focus-ring": "2px solid var(--accent)",
    "--focus-offset": "2px"
  },
  "transitions": {
    "--transition-fast": "0.15s ease-out",
    "--transition-normal": "0.25s ease-out",
    "--toast-duration": "4s"
  },
  "layout": {
    "--toolbar-height": "44px",
    "--statusbar-height": "28px"
  },
  "layers": {
    "--layer-base": 0,
    "--layer-raised": 10,
    "--layer-sticky": 100,
    "--layer-overlay": 500,
    "--layer-dropdown": 1000,
    "--layer-modal": 2000,
    "--layer-toast": 5000,
    "--layer-top": 9999
  },
  "shadows": {
    "--shadow-sm": "0 1px 4px rgba(0, 0, 0, 0.25)",
    "--shadow-md": "0 4px 16px rgba(0, 0, 0, 0.25)",
    "--shadow-lg": "0 16px 48px rgba(0, 0, 0, 0.4)",
    "--shadow-overlay": "-4px 0 20px rgba(0, 0, 0, 0.25)"
  },
  "overlays": {
    "--overlay-bg": "rgba(0, 0, 0, 0.55)",
    "--overlay-border": "var(--border)"
  },
  "highlights": {
    "--highlight-subtle": "rgba(255, 255, 255, 0.025)",
    "--highlight-hover": "rgba(255, 255, 255, 0.05)",
    "--diff-add-bg": "rgba(34, 197, 94, 0.1)",
    "--diff-remove-bg": "rgba(239, 68, 68, 0.1)",
    "--terminal-selection": "rgba(99, 102, 241, 0.35)"
  }
}
