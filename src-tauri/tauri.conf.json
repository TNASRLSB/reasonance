{
  "$schema": "https://raw.githubusercontent.com/nicholasVilela/tauri-v2-schema/refs/heads/master/tauri-conf-schema.json",
  "productName": "Reasonance",
  "version": "0.2.0",
  "identifier": "com.reasonance.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Reasonance",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.anthropic.com https://api.openai.com https://generativelanguage.googleapis.com; img-src 'self' data: blob:; font-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TNASRLSB/reasonance/releases/latest/download/latest.json"
      ],
      "pubkey": dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBRjUzRkJCNjlEQkRGMDUKUldRRjM5dHB1ei8xaWxqSXpENjh2WTZPTjVnWS9UcmxJSmtOUURZR2xFY0VsMG5FLzNKa0l5SnkK
    }
  }
}
