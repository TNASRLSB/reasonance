{
  "$schema": "https://raw.githubusercontent.com/nicholasVilela/tauri-v2-schema/refs/heads/master/tauri-conf-schema.json",
  "productName": "Forge IDE",
  "version": "0.1.0",
  "identifier": "com.forgeide.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Forge IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {
      "openUrl": {
        "enabled": true
      }
    }
  }
}
